# ── Authentication ─────────────────────────────────────────────
# Set both to enable login protection. Omit both to run without auth.
# PINCER_USERNAME=admin
# PINCER_PASSWORD=changeme

# Optional: override the HMAC signing secret (defaults to PINCER_PASSWORD)
# PINCER_SESSION_SECRET=your-random-secret-here

# Set to "true" to explicitly disable auth even if credentials are set
# PINCER_AUTH_DISABLED=true
